<!DOCTYPE index.html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>Meta AI</title>
  <meta name="description" content="Use Meta AI assistant to get things done, create AI images, and get answers.">

  <link rel="icon" href="/favicon.ico">
  <link rel="manifest" href="/manifest.json">

  <!-- Main styles -->
  <link rel="stylesheet" href="/_next/static/chunks/styles.css">

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #1a1a1a;
      color: white;
    }

    .loading {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }

    .spinner {
      width: 40px;
      height: 40px;
      border: 3px solid #fff;
      border-top: 3px solid transparent;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      100% { transform: rotate(360deg); }
    }

    iframe {
      width: 100%;
      height: 100vh;
      border: none;
      opacity: 0;
    }
  </style>
</head>

<body>

  <div id="app">
    <div class="loading">
      <div class="spinner"></div>
    </div>

    <iframe title="Shared artefact"></iframe>
  </div>

  <!-- JS bundles (Meta AI / Next.js) -->
  <script src="/_next/static/chunks/runtime.js"></script>
  <script src="/_next/static/chunks/main.js"></script>
  <script src="/_next/static/chunks/app.js"></script>

</body>
</html>